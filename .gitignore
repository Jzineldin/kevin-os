node_modules/
dist/
*.tsbuildinfo
cdk.out/
.env
.env.local
*.log
coverage/

# CDK deploy artifacts (generated at `cdk deploy` time — not source)
cdk-outputs.json
cdk-deploy*.log

# Claude Code session state (IDE-local)
# .claude/ contains agent definitions we want tracked (SOUL.md, BOOT.md,
# per-agent markdown). Ignore only session-level scratch.
.claude/sessions/
.claude/worktrees/
.claude/scheduled_tasks.lock
.claude/tasks/
.claude/agents_cache/
.claude/cache/
.claude/*.local.md

# Kilo CLI session state (IDE-local — local skills/node_modules/config,
# never committed; project-wide .kilo/command/.kilo/agent lives elsewhere).
.kilo/

# Drizzle migration SQL + _journal.json are source-controlled (schema history).
# If drizzle-kit ever introduces an ignorable subdirectory, ignore that path
# specifically — don't blanket-ignore packages/db/drizzle/.

cdk.out.dashboard/
.vercel/

# CDK test temp dir — vitest globalSetup redirects os.tmpdir() here so
# `cdk.out*` synth artifacts don't accumulate in /tmp on shared hosts.
packages/cdk/.cdk-tmp/
services/openclaw-bridge/.env.test
