# Kevin OS dashboard — required environment variables
#
# For Vercel production/preview/development: populate via
#   pnpm sync-vercel
# (scripts/sync-vercel-env.ts reads AWS Secrets Manager + the KosDashboard
#  CloudFormation outputs and writes to Vercel).
#
# For local `next dev`: copy this file to `.env.local` and fill each value
# by hand. Do NOT check `.env.local` into git.

# --- Auth ---------------------------------------------------------------

# Bearer token Kevin pastes on the /login page. Must match the value stored
# in AWS Secrets Manager at `kos/dashboard-bearer-token` (field: "token").
# Generate with: node -e "console.log(crypto.randomUUID()+crypto.randomUUID())"
KOS_DASHBOARD_BEARER_TOKEN=

# Single-user owner_id. Hardcoded in sync-vercel-env.ts; listed here for
# local-dev parity. Do not change — every RDS row is tagged with it.
KOS_OWNER_ID=7a6b5c4d-3e2f-4a09-8b7c-6d5e4f3a2b1c

# --- AWS backend ingress (Plan 03-04 outputs) ----------------------------

# Dashboard-api Lambda Function URL (AWS_IAM auth, SigV4 required).
# Populated from CloudFormation output `DashboardApiFunctionUrl`.
KOS_DASHBOARD_API_URL=

# Relay-proxy Lambda Function URL (Option B ingress to Fargate relay).
# Populated from CloudFormation output `RelayProxyFunctionUrl`.
KOS_DASHBOARD_RELAY_URL=

# SigV4 caller credentials (IAM user `kos-dashboard-caller`; policy grants
# only `lambda:InvokeFunctionUrl` on the two Function URLs above).
# Generate via: aws iam create-access-key --user-name kos-dashboard-caller
# Store result in Secrets Manager at `kos/dashboard-caller-access-keys`.
AWS_ACCESS_KEY_ID_DASHBOARD=
AWS_SECRET_ACCESS_KEY_DASHBOARD=

# AWS region for both the Function URL and SigV4 signing.
AWS_REGION=eu-north-1

# --- Observability (Plan 03-06 + 03-12) ---------------------------------

# Sentry DSN for the dashboard project (kos-dashboard). The same value is
# exposed to both the client bundle (NEXT_PUBLIC_) and the server.
# Stored in Secrets Manager at `kos/sentry-dsn-dashboard`.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
