{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "..",
    "outDir": "dist",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@opentelemetry/*": ["./node_modules/@opentelemetry/*"],
      "@langfuse/*": ["./node_modules/@langfuse/*"],
      "@arizeai/*": ["./node_modules/@arizeai/*"],
      "@sentry/*": ["./node_modules/@sentry/*"],
      "@aws-sdk/*": ["./node_modules/@aws-sdk/*"],
      "@kos/*": ["./node_modules/@kos/*/src/index.ts", "./node_modules/@kos/*"]
    }
  },
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
